APP_NAME="DropPilot"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Europe/Berlin
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# MySQL / MariaDB
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=droppilot
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# Queue: redis (lokalde Homebrew), prod'da Redis yoksa "database" yap
QUEUE_CONNECTION=redis
HORIZON_PREFIX=droppilot:horizon:

# Cache: redis (lokalde Homebrew), prod'da Redis yoksa "database" yap
CACHE_STORE=redis
CACHE_PREFIX=droppilot

MEMCACHED_HOST=127.0.0.1

# PHP redis extension yok ise predis kullan
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@droppilot.local"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ─────────────────────────────────────────────────────────
# Shopify App (kyon147/laravel-shopify)
# ─────────────────────────────────────────────────────────
SHOPIFY_APP_NAME="DropPilot"
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_API_VERSION=2026-04
SHOPIFY_API_SCOPES="read_orders,write_orders,read_products,write_products,read_inventory,write_inventory,read_customers,read_fulfillments,write_fulfillments,read_assigned_fulfillment_orders,write_assigned_fulfillment_orders"
SHOPIFY_SHOP_AUTH_PROVIDER=shopify_stores
SHOPIFY_SHOP_AUTH_GUARD=shopify
SHOPIFY_MANUAL_MIGRATIONS=true
SHOPIFY_EXPIRING_OFFLINE_TOKENS=true
SHOPIFY_API_GRANT_MODE=OFFLINE
SHOPIFY_API_REDIRECT=/authenticate
SHOPIFY_DEBUG=true
